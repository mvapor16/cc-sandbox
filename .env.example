# ── .env.example ──────────────────────────────────────────────────────────────
# This file is a TEMPLATE. Copy it to .env and fill in your real values.
# The real .env file is in .gitignore and will never be committed.
#
# NEVER paste your actual keys into this file — it IS committed to GitHub.
# ──────────────────────────────────────────────────────────────────────────────


# ── Option A: Standard Anthropic API (personal account) ───────────────────────
# Get your key from: https://console.anthropic.com
# It starts with: sk-ant-
#
# ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── Option B: McKinsey AI Gateway (for McKinsey colleagues) ───────────────────
# These tokens expire. Refresh them from your McKinsey AI gateway portal.
#
# ANTHROPIC_BASE_URL=https://anthropic.prod.ai-gateway.quantumblack.com/47c10fd0-4885-4851-9424-5487a2b8ffed
# ANTHROPIC_API_KEY=your-jwt-token-from-mckinsey-portal
